{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "concurrently \"vite\" \"node socket-server.js\" --names=\"vite,socket\" -c \"cyan,magenta\"",
        "socket": "node socket-server.js",
        "vercel-build": "vite build",
        "deploy": "npm run build && git add . && git commit -m 'Deploy to Vercel' && git push"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@tiptap/core": "^3.23.5",
        "@tiptap/pm": "^3.23.5",
        "@tiptap/starter-kit": "^3.23.5",
        "alpinejs": "^3.15.12",
        "aos": "^2.3.4",
        "express": "^5.2.1",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3"
    }
}
